<%
  const totalPages = Math.max(1, Math.ceil((total || 0) / page.pageSize));
  const normalizePage = (targetPage) => Math.min(totalPages, Math.max(1, Number(targetPage) || 1));
  const buildUrl = (targetPage, nextPageSize = page.pageSize) => {
    const params = new URLSearchParams();
    Object.entries(filters || {}).forEach(([key, value]) => {
      if (Array.isArray(value)) {
        value.forEach((item) => {
          if (item) params.append(key, item);
        });
        return;
      }
      if (value) params.set(key, value);
    });
    params.set('page', normalizePage(targetPage));
    params.set('pageSize', nextPageSize);
    return `${basePath}?${params.toString()}`;
  };
  const filterEntries = Object.entries(filters || {});
  const pages = [];
  const addPage = (value) => {
    if (!pages.includes(value)) pages.push(value);
  };

  addPage(1);
  for (let current = page.page - 2; current <= page.page + 2; current += 1) {
    if (current > 1 && current < totalPages) addPage(current);
  }
  if (totalPages > 1) addPage(totalPages);
  pages.sort((a, b) => a - b);
%>
<div class="pagination-row">
  <span class="pagination-total">共 <%= total || 0 %> 条</span>
  <form class="page-size-form" method="get" action="<%= basePath %>">
    <% filterEntries.forEach(([key, value]) => { %>
      <% if (Array.isArray(value)) { %>
        <% value.forEach((item) => { %>
          <% if (item) { %><input type="hidden" name="<%= key %>" value="<%= item %>"><% } %>
        <% }) %>
      <% } else if (value) { %>
        <input type="hidden" name="<%= key %>" value="<%= value %>">
      <% } %>
    <% }) %>
    <input type="hidden" name="page" value="1">
    <label class="page-size-label">
      <select class="form-select form-select-sm page-size-select" name="pageSize" data-page-size-select>
        <% [20, 50, 100].forEach((size) => { %>
          <option value="<%= size %>" <%= page.pageSize === size ? 'selected' : '' %>><%= size %>条/页</option>
        <% }) %>
      </select>
    </label>
  </form>
  <nav class="pagination-pages" aria-label="分页">
    <a class="pagination-arrow <%= page.page <= 1 ? 'disabled' : '' %>" href="<%= buildUrl(page.page - 1) %>" aria-label="上一页">‹</a>
    <% pages.forEach((pageNumber, index) => { %>
      <% if (index > 0 && pageNumber - pages[index - 1] > 1) { %>
        <span class="pagination-ellipsis">•••</span>
      <% } %>
      <a class="pagination-page <%= page.page === pageNumber ? 'active' : '' %>" href="<%= buildUrl(pageNumber) %>"><%= pageNumber %></a>
    <% }) %>
    <a class="pagination-arrow <%= page.page >= totalPages ? 'disabled' : '' %>" href="<%= buildUrl(page.page + 1) %>" aria-label="下一页">›</a>
  </nav>
  <form class="page-jump-form" method="get" action="<%= basePath %>" data-page-jump-form data-total-pages="<%= totalPages %>">
    <% filterEntries.forEach(([key, value]) => { %>
      <% if (Array.isArray(value)) { %>
        <% value.forEach((item) => { %>
          <% if (item) { %><input type="hidden" name="<%= key %>" value="<%= item %>"><% } %>
        <% }) %>
      <% } else if (value) { %>
        <input type="hidden" name="<%= key %>" value="<%= value %>">
      <% } %>
    <% }) %>
    <input type="hidden" name="pageSize" value="<%= page.pageSize %>">
    <span>前往</span>
    <input class="page-jump-input" type="number" min="1" max="<%= totalPages %>" name="page" value="<%= page.page %>" data-page-jump-input>
    <span>页</span>
  </form>
</div>
