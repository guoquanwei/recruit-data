<%- include('../../partials/header') %>

<%
  const detailPayload = {};
  const detailColumns = ['状态', '工号', '姓名', '招聘渠道', '渠道名称', '入培日期', '是否在职', '离职日期', '在职天数'];
  const toDetailRows = (rows = []) => rows.map((row) => ({
    '状态': row.status,
    '工号': row.employeeNo,
    '姓名': row.name,
    '招聘渠道': row.channelType,
    '渠道名称': row.channelName,
    '入培日期': row.trainingDate,
    '是否在职': row.employeeStatus,
    '离职日期': row.resignedDate,
    '在职天数': row.workDays
  }));
  const addDetailPayload = (key, title, rows) => {
    detailPayload[key] = {
      title,
      columns: detailColumns,
      rows: toDetailRows(rows)
    };
  };
  const detailButton = (key, value) => (
    `<button type="button" class="detail-number" data-detail-key="${key}">${value}</button>`
  );
%>

<section class="filter-card">
  <form method="get" class="row g-3 align-items-end">
    <div class="col-md-3">
      <label class="form-label">月份</label>
      <input class="form-control" type="month" name="yearMonth" value="<%= dashboard.yearMonth %>">
    </div>
    <div class="col-md-3">
      <label class="form-label">招聘专员</label>
      <select class="form-select" name="recruiter">
        <option value="">全部招聘专员</option>
        <% dashboard.selfSourcingRecruiterOptions.forEach((recruiter) => { %>
          <option value="<%= recruiter %>" <%= dashboard.filters.recruiter === recruiter ? 'selected' : '' %>><%= recruiter %></option>
        <% }) %>
      </select>
    </div>
    <div class="col-md-3">
      <button class="btn btn-primary" type="submit">查询</button>
      <a class="btn btn-outline-secondary" href="/dashboard/self-sourcing">重置</a>
    </div>
  </form>
</section>

<section class="table-card mb-3">
  <h2 class="h5">自主社招人效</h2>
  <div class="table-responsive">
    <table class="table table-hover">
      <thead><tr><th>阶段</th><th>招聘规模</th><th>参培达成</th><th>7 天达成</th><th>人效</th></tr></thead>
      <tbody>
        <% dashboard.selfSourcingEfficiency.forEach((item) => { %>
          <tr>
            <td><%= item.stage %></td>
            <td><%= item.recruiterCount %></td>
            <td><%= item.trainingCount %></td>
            <td><%= item.sevenDayCount %></td>
            <td><%= item.efficiency %> / 满7天 <%= item.sevenDayEfficiency %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<section class="table-card">
  <h2 class="h5">自主社招招聘专员达成</h2>
  <div class="table-responsive">
    <table class="table table-hover align-middle self-sourcing-recruiter-table">
      <colgroup>
        <col class="col-name">
        <col class="col-employee-no">
        <col class="col-date">
        <col class="col-status">
        <col class="col-target">
        <col class="col-target">
        <col class="col-count">
        <col class="col-target">
        <col class="col-target">
        <col class="col-count">
        <col class="col-efficiency">
        <col class="col-efficiency">
        <% const monthColumns = dashboard.selfSourcingRecruiterRows[0]?.months || []; %>
        <% monthColumns.forEach(() => { %>
          <col class="col-month">
        <% }) %>
        <col class="col-trend">
      </colgroup>
      <thead>
        <tr>
          <th>姓名</th>
          <th>工号</th>
          <th>入职日期</th>
          <th>是否在职</th>
          <th>当月入培目标</th>
          <th>当月截止目标</th>
          <th>实际达成</th>
          <th>7天入培目标</th>
          <th>7天截止目标</th>
          <th>7天实际留存</th>
          <th>截止月均7天人效</th>
          <th>累计7天人效</th>
          <% monthColumns.forEach((month) => { %>
            <th><%= month.label %></th>
          <% }) %>
          <th>趋势</th>
        </tr>
      </thead>
      <tbody>
        <% if (dashboard.selfSourcingRecruiterRows.length === 0) { %>
          <tr><td class="text-center text-muted" colspan="<%= 13 + (dashboard.selfSourcingRecruiterRows[0]?.months.length || 0) %>">暂无符合筛选条件的招聘专员达成数据。</td></tr>
        <% } %>
        <% dashboard.selfSourcingRecruiterRows.forEach((item) => { %>
          <% const values = item.months.map((month) => month.sevenDayRetainedCount); %>
          <% const maxValue = Math.max(...values, 1); %>
          <% const points = values.map((value, index) => `${values.length === 1 ? 50 : (index / (values.length - 1) * 100).toFixed(1)},${(32 - value / maxValue * 28).toFixed(1)}`).join(' '); %>
          <% addDetailPayload(`actual-${item.name}`, `${item.name} - 实际达成明细`, item.actualDetails); %>
          <% addDetailPayload(`seven-${item.name}`, `${item.name} - 7天留存明细`, item.sevenDayRetainedDetails); %>
          <tr>
            <td><%= item.name %></td>
            <td><%= item.employeeNo || '--' %></td>
            <td><%= item.entryDate || '--' %></td>
            <td><%= item.employeeStatus %></td>
            <td>--</td>
            <td>--</td>
            <td><%- detailButton(`actual-${item.name}`, item.actualAchievement) %></td>
            <td>--</td>
            <td>--</td>
            <td><%- detailButton(`seven-${item.name}`, item.sevenDayRetainedCount) %></td>
            <td><%= item.cutoffMonthlyAverageSevenDayEfficiency %></td>
            <td><%= item.cumulativeSevenDayEfficiency %></td>
            <% item.months.forEach((month) => { %>
              <% addDetailPayload(`month-${item.name}-${month.yearMonth}`, `${item.name} - ${month.label} 7天留存明细`, month.sevenDayRetainedDetails); %>
              <td><%- detailButton(`month-${item.name}-${month.yearMonth}`, month.sevenDayRetainedCount) %></td>
            <% }) %>
            <td>
              <svg class="mini-sparkline" viewBox="0 0 100 36" role="img" aria-label="7天留存趋势">
                <polyline points="<%= points %>" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"></polyline>
              </svg>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<div id="detailModal" class="modal-mask" data-detail-modal>
  <div class="modal-panel" role="dialog" aria-modal="true" aria-labelledby="detailModalTitle">
    <div class="modal-head">
      <h2 id="detailModalTitle">明细</h2>
      <button type="button" class="modal-close" data-detail-close>关闭</button>
    </div>
    <div id="detailModalBody" class="modal-body"></div>
  </div>
</div>

<script id="detailPayload" type="application/json"><%- JSON.stringify(detailPayload).replace(/</g, '\\u003c') %></script>
<script>
  (() => {
    const payload = JSON.parse(document.getElementById('detailPayload').textContent);
    const modal = document.querySelector('[data-detail-modal]');
    const title = document.getElementById('detailModalTitle');
    const body = document.getElementById('detailModalBody');
    const escapeHtml = (value) => String(value ?? '').replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;'
    }[char]));
    const openDetail = (key) => {
      const item = payload[key];
      if (!item) return;
      title.textContent = item.title;
      if (!item.rows.length) {
        body.innerHTML = '<p class="muted">暂无匹配人员明细</p>';
      } else {
        const head = item.columns.map((column) => `<th>${escapeHtml(column)}</th>`).join('');
        const rows = item.rows.map((row) => {
          const cells = item.columns.map((column) => `<td>${escapeHtml(row[column])}</td>`).join('');
          return `<tr>${cells}</tr>`;
        }).join('');
        body.innerHTML = `<div class="table-responsive"><table class="table table-hover"><thead><tr>${head}</tr></thead><tbody>${rows}</tbody></table></div>`;
      }
      modal.classList.add('open');
    };
    const closeDetail = () => modal.classList.remove('open');
    document.addEventListener('click', (event) => {
      const button = event.target.closest('[data-detail-key]');
      if (button) {
        openDetail(button.dataset.detailKey);
        return;
      }
      if (event.target === modal || event.target.closest('[data-detail-close]')) {
        closeDetail();
      }
    });
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeDetail();
    });
  })();
</script>

<%- include('../../partials/footer') %>
