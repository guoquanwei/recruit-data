<%
  const boardPath = typeof dashboardPath !== 'undefined' ? dashboardPath : '/dashboard/base-risk';
  const buildDashboardUrl = (overrides = {}) => {
    const params = new URLSearchParams();
    const values = {
      yearMonth: dashboard.yearMonth,
      base: dashboard.filters.base,
      channel: dashboard.filters.channel,
      selectedBase: dashboard.selectedCell.base,
      selectedChannel: dashboard.selectedCell.channel,
      selectedBatchDay: dashboard.selectedCell.selectedBatchDay,
      ...overrides
    };

    Object.entries(values).forEach(([key, value]) => {
      if (value !== undefined && value !== null && value !== '') {
        params.set(key, value);
      }
    });

    return `${boardPath}?${params.toString()}`;
  };
  const positionBoard = dashboard.positionBoard;
  const isBaseOverview = positionBoard.mode === 'baseOverview';
  const riskBatchCount = isBaseOverview
    ? positionBoard.riskBaseCount
    : (positionBoard.healthStatus === 'healthy'
      ? 0
      : positionBoard.batchRisks.filter((batch) => batch.status === 'risk' || batch.status === 'warning').length);
  const contributionTotal = Math.max(
    positionBoard.total.monthlyTarget,
    isBaseOverview
      ? positionBoard.baseAchievements.reduce((sum, base) => sum + base.actualTraining, 0)
      : positionBoard.channels.reduce((sum, channel) => sum + channel.actualTraining, 0),
    1
  );
%>

<div class="metric-grid position-metric-grid">
  <div class="metric-card"><span><%= isBaseOverview ? '整体月目标' : '岗位月目标' %></span><strong><%= positionBoard.total.monthlyTarget %></strong></div>
  <div class="metric-card"><span>已入职</span><strong><%= positionBoard.total.actualTraining %></strong></div>
  <div class="metric-card <%= positionBoard.total.gap < 0 ? 'danger' : '' %>"><span>GAP</span><strong><%= positionBoard.total.gap %></strong></div>
  <div class="metric-card <%= positionBoard.total.achievementRate < 1 ? 'danger' : '' %>"><span>达成率</span><strong><%= positionBoard.total.achievementRateText %></strong></div>
  <div class="metric-card danger"><span><%= isBaseOverview ? '风险基地' : '风险批次' %></span><strong><%= riskBatchCount %></strong></div>
</div>

<div class="position-board-grid">
  <section class="table-card position-goal-card">
    <div class="table-actions">
      <div>
        <h2 class="h5 mb-1"><%= positionBoard.title %></h2>
        <p class="section-note"><%= isBaseOverview ? '基地选择全部时，先按目标达成率判断各基地是否风险或预警。' : '多渠道共同满足同一个岗位目标，先看整体 GAP，再判断批次和渠道漏斗。' %></p>
      </div>
      <span class="position-status position-status-<%= positionBoard.total.status %>"><%= positionBoard.total.statusText %></span>
    </div>

    <% if (isBaseOverview) { %>
      <div class="base-achievement-list">
        <% positionBoard.baseAchievements.forEach((base) => { %>
          <a class="base-achievement-item base-achievement-<%= base.status %>" href="<%= buildDashboardUrl({ base: base.base, selectedBase: base.base, selectedChannel: '', selectedBatchDay: '' }) %>">
            <div>
              <strong><%= base.base %></strong>
              <span>目标 <%= base.monthlyTarget %> · 已入职 <%= base.actualTraining %> · GAP <%= base.gap %></span>
            </div>
            <div class="base-achievement-progress">
              <i style="width: <%= Math.min(100, Math.max(0, base.achievementRate * 100)) %>%"></i>
            </div>
            <span class="position-status position-status-<%= base.status %>"><%= base.statusText %></span>
            <b><%= base.achievementRateText %></b>
          </a>
        <% }) %>
      </div>
    <% } else { %>
      <div class="channel-stack-head">
        <span>多渠道入职贡献（单位：人）</span>
        <strong>目标 <%= positionBoard.total.monthlyTarget %> 人</strong>
      </div>
      <div class="channel-stack-bar" aria-label="多渠道入职贡献">
        <% positionBoard.channels.forEach((channel, index) => { %>
          <% const width = channel.actualTraining > 0 ? Math.max(5, channel.actualTraining / contributionTotal * 100) : 0; %>
          <span class="channel-stack-segment channel-color-<%= index % 5 %>" style="width: <%= width %>%">
            <%= channel.actualTraining %>
          </span>
        <% }) %>
        <em class="channel-target-marker"><%= positionBoard.total.monthlyTarget %></em>
      </div>
      <div class="channel-stack-legend">
        <% positionBoard.channels.forEach((channel, index) => { %>
          <span><i class="channel-color-<%= index % 5 %>"></i><%= channel.channel %>（<%= channel.actualTraining %>）</span>
        <% }) %>
      </div>

      <div class="table-responsive mt-3">
        <table class="table channel-health-table">
          <thead>
            <tr>
              <th>渠道</th>
              <th>月目标</th>
              <th>已入职</th>
              <th>GAP</th>
              <th>漏斗健康度</th>
            </tr>
          </thead>
          <tbody>
            <% positionBoard.channels.forEach((channel) => { %>
              <tr>
                <td><span class="channel-dot channel-dot-<%= channel.status %>" title="<%= channel.statusText %>"></span><%= channel.channel %></td>
                <td><%= channel.monthlyTarget %></td>
                <td><%= channel.actualTraining %></td>
                <td class="<%= channel.gap < 0 ? 'danger-text strong-text' : '' %>"><%= channel.gap %></td>
                <td><span class="position-status position-status-<%= channel.status %>"><%= channel.statusText %></span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <div class="embedded-batch-section">
        <div class="selected-batch-head">
          <div>
            <h2 class="h6 mb-1">批次漏斗概览 <span data-selected-batch-label><%= positionBoard.selectedBatch ? `已选择：${positionBoard.selectedBatch.label}` : '' %></span></h2>
            <p class="section-note mb-0">点击批次切换右侧诊断数据。</p>
          </div>
        </div>
        <% if (!positionBoard.selectedBatch) { %>
          <div class="empty-card mt-3">暂无批次数据。</div>
        <% } else { %>
          <div class="batch-risk-grid embedded-batch-grid mt-3">
            <% if (positionBoard.batchRisks.length === 0) { %>
              <div class="empty-card">暂无批次数据。</div>
            <% } %>
            <% positionBoard.batchRisks.forEach((batch) => { %>
              <a class="batch-risk-card batch-risk-<%= batch.status %> <%= positionBoard.selectedBatch && positionBoard.selectedBatch.day === batch.day ? 'active' : '' %>" href="<%= buildDashboardUrl({ selectedBase: positionBoard.base, selectedBatchDay: batch.day }) %>" data-position-batch-card data-batch-day="<%= batch.day %>">
                <div class="batch-risk-summary">
                  <div class="batch-risk-title">
                    <strong><%= batch.label %></strong>
                    <span><%= batch.statusText %></span>
                  </div>
                  <small>GAP</small>
                  <b class="<%= batch.gap < 0 ? 'danger-text' : '' %>"><%= batch.gap %></b>
                  <em>目标 <%= batch.target %> · 已入职 <%= batch.actualTraining %></em>
                </div>
                <div class="batch-channel-breakdown">
                  <% batch.channels.forEach((channel) => { %>
                    <span class="batch-channel-row">
                      <strong><%= channel.channel %></strong>
                      <em>目标 <%= channel.target %></em>
                      <em>已入职 <%= channel.actualTraining %></em>
                      <b class="<%= channel.gap < 0 ? 'danger-text' : '' %>">GAP <%= channel.gap %></b>
                    </span>
                  <% }) %>
                </div>
              </a>
            <% }) %>
          </div>
        <% } %>
      </div>
    <% } %>
  </section>

  <section class="table-card position-diagnosis-card">
    <div class="table-actions">
      <div>
        <h2 class="h5 mb-1">漏斗诊断与提升方案</h2>
        <p class="section-note" data-position-main-risk-text><%= isBaseOverview ? '选择具体基地后，可查看健康判断和分渠道动作。' : positionBoard.mainRiskText %></p>
      </div>
    </div>
    <% if (isBaseOverview) { %>
      <div class="empty-card">选择具体基地后，可在首屏查看漏斗诊断和提升方案。</div>
    <% } else if (!positionBoard.selectedBatch) { %>
      <div class="empty-card">暂无漏斗诊断数据。</div>
    <% } else { %>
      <div class="funnel-analysis-layout">
        <div class="table-responsive">
          <table class="table funnel-diagnosis-table">
            <thead>
              <tr>
                <th>渠道</th>
                <th>状态</th>
                <th>到面人数</th>
                <th>面通人数</th>
                <th>参培人数</th>
                <th>面通率</th>
                <th>参培率</th>
              </tr>
            </thead>
            <tbody data-funnel-diagnosis-body>
              <% positionBoard.funnelRows.forEach((row) => { %>
                <tr>
                  <td><span class="channel-dot channel-dot-<%= row.status %>" title="<%= row.statusText %>"></span><%= row.channel %></td>
                  <td><span class="position-status position-status-<%= row.status %>"><%= row.statusText %></span></td>
                  <td><%= row.arrivedCount %></td>
                  <td><%= row.passedCount %></td>
                  <td><%= row.trainingCount %></td>
                  <td><%= row.passRateText %></td>
                  <td><%= row.trainingRateText %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <div class="channel-action-grid" data-channel-action-grid>
          <% positionBoard.actionPlans.forEach((plan) => { %>
            <article class="channel-action-card channel-action-<%= plan.status %>">
              <div class="channel-action-head">
                <h3><%= plan.title %></h3>
                <span><%= plan.owner %> · <%= plan.statusText %></span>
              </div>
              <em>关注：<%= plan.focus %></em>
              <p><%= plan.diagnosis %></p>
              <% if (plan.communicationScript) { %>
                <blockquote><%= plan.communicationScript %></blockquote>
              <% } %>
              <ol>
                <% plan.actions.forEach((action) => { %>
                  <li><%= action %></li>
                <% }) %>
              </ol>
            </article>
          <% }) %>
        </div>
      </div>
    <% } %>
  </section>
</div>

<% if (!isBaseOverview) { %>
  <script id="positionBatchPayload" type="application/json"><%- JSON.stringify({
    selectedBatchDay: positionBoard.selectedBatch?.day,
    batches: positionBoard.batchRisks.map((batch) => ({
      day: batch.day,
      label: batch.label,
      funnelRows: batch.funnelRows,
      actionPlans: batch.actionPlans || [],
      mainRiskText: batch.mainRiskText || positionBoard.mainRiskText || ''
    }))
  }).replace(/</g, '\\u003c') %></script>
<% } %>
