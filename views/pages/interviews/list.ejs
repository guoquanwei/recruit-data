<%- include('../../partials/header') %>

<section class="filter-card">
  <form method="get">
    <div class="filter-grid">
      <%- include('../../partials/admin/search-select', { label: '月份', name: 'yearMonth', value: result.filters.yearMonth, items: result.options.months }) %>
      <%- include('../../partials/admin/search-select', { label: '基地', name: 'base', value: result.filters.base, items: result.options.bases }) %>
      <%- include('../../partials/admin/search-select', { label: '招聘渠道', name: 'channelType', value: result.filters.channelType, items: result.options.channelTypes }) %>
      <%- include('../../partials/admin/search-select', { label: '渠道名称', name: 'channelName', value: result.filters.channelName, items: result.options.channelNames }) %>
      <div class="filter-actions">
        <button class="btn btn-primary" type="submit">查询</button>
        <button class="btn btn-outline-secondary" type="button" data-reset-form>重置</button>
      </div>
    </div>
  </form>
</section>

<section class="table-card">
  <%
    const interviewExportParams = new URLSearchParams();
    Object.entries(result.filters).forEach(([key, value]) => {
      if (value) interviewExportParams.set(key, value);
    });
  %>
  <div class="table-actions">
    <h2 class="h5 mb-0">面试记录列表</h2>
    <div class="table-action-buttons">
      <a class="btn btn-sm btn-outline-secondary" href="<%= `/interviews/export?${interviewExportParams.toString()}` %>">导出</a>
    </div>
  </div>
  <div class="table-responsive">
    <table class="table table-hover align-middle">
      <thead>
        <tr>
          <th>基地</th><th>职位名称</th><th>候选人</th><th>性别</th><th>电话</th><th>反馈日期</th>
          <th>反馈结果</th><th>面试官</th><th>招聘渠道</th><th>渠道名称</th><th>内推人</th><th>综合评价</th>
        </tr>
      </thead>
      <tbody>
        <% if (result.rows.length === 0) { %>
          <tr><td class="text-center text-muted" colspan="12"><%= result.emptyMessage || '暂无面试记录，请先导入面试记录。' %></td></tr>
        <% } %>
        <% result.rows.forEach((record) => { %>
          <tr>
            <td><%= record.base %></td>
            <td><%= record.positionName %></td>
            <td><%= record.candidateName %></td>
            <td><%= record.gender %></td>
            <td><%= record.maskedPhone %></td>
            <td><%= record.feedbackDate %></td>
            <td><%= record.feedbackResult %></td>
            <td><%= record.interviewer %></td>
            <td><%= record.channelType %></td>
            <td><%= record.channelName %></td>
            <td><%= record.referrer %></td>
            <td><%= record.evaluation %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <%- include('../../partials/admin/pagination', { total: result.total, page: result.page, filters: result.filters, basePath: '/interviews' }) %>
</section>

<%- include('../../partials/footer') %>
