<%- include('../../partials/header') %>

<% if (notice) { %><div class="alert alert-success"><%= notice %></div><% } %>
<% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

<section class="import-card">
  <div class="import-card-head">
    <div>
      <h2 class="h5 mb-1">面试记录导入</h2>
      <p class="text-muted small mb-0">支持按日覆盖和历史全量覆盖。按日覆盖以「面试官填写反馈时间」中的日期列表为覆盖范围。</p>
    </div>
  </div>
  <form action="/interviews/import" method="post" enctype="multipart/form-data">
    <div class="row g-3">
      <div class="col-md-4">
        <label class="form-label">导入模式</label>
        <select class="form-select" name="mode">
          <option value="daily_overwrite">按日覆盖</option>
          <option value="full_overwrite">历史全量覆盖</option>
        </select>
      </div>
      <div class="col-md-6">
        <label class="form-label">选择 Excel 文件</label>
        <input class="form-control" type="file" name="file" accept=".xlsx,.xls" required>
      </div>
    </div>
    <div class="import-action-row mt-3">
      <button class="btn btn-primary" type="submit">导入面试记录</button>
      <a class="btn btn-outline-primary" href="/interviews/import/template">下载 Excel 模板</a>
    </div>
  </form>
  <div class="import-field-guide">
    <h3>字段规范说明</h3>
    <dl>
      <dt>工作表名称</dt>
      <dd>建议使用「面试记录」；系统读取第一个工作表。</dd>
      <dt>必填列</dt>
      <dd><span class="required-columns">职位名称、候选人名称、电话、面试官填写反馈时间、面试官反馈结果、面试官、猎头公司标签</span></dd>
      <dt>字段格式</dt>
      <dd>面试官填写反馈时间使用 YYYY-MM-DD，例如 2026-06-01；电话建议设置为文本格式，禁止科学计数法。</dd>
      <dt>导入模式</dt>
      <dd>按日覆盖会先删除表格日期列表对应的旧数据，再插入本次 Excel 的最新数据；历史全量覆盖会替换全部面试记录。</dd>
      <dt>校验规则</dt>
      <dd>必填列禁止空值；表头必须在第 1 行，禁止改名、合并单元格、换行或添加特殊符号。</dd>
      <dt>可选列</dt>
      <dd>性别、猎头合约名称、内推人、综合评价。</dd>
    </dl>
  </div>
</section>

<%- include('../../partials/footer') %>
