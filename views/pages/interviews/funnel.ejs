<%- include('../../partials/header') %>

<section class="filter-card">
  <form method="get" class="row g-3 align-items-end">
    <div class="col-md-3">
      <label class="form-label">月份</label>
      <input class="form-control" type="month" name="yearMonth" value="<%= funnel.filters.yearMonth %>">
    </div>
    <div class="col-md-3">
      <%- include('../../partials/admin/search-select', { label: '基地', name: 'base', value: funnel.filters.base, items: funnel.options.bases }) %>
    </div>
    <div class="col-md-3">
        <button class="btn btn-primary" type="submit">查询</button>
        <button class="btn btn-outline-secondary" type="button" data-reset-form>重置</button>
    </div>
  </form>
</section>

<section class="table-card">
  <h2 class="h5">月度招聘漏斗转化数据</h2>
  <div class="table-responsive">
    <table class="table table-hover target-progress-detail-table">
      <thead><tr class="frozen-header-row"><th>基地</th><th>到面数</th><th>面通数</th><th>参培数</th><th>面通率</th><th>参培率</th></tr></thead>
      <tbody>
        <% if (funnel.monthlyRows.length === 0) { %>
          <tr><td class="text-center text-muted" colspan="6">暂无月度招聘漏斗转化数据。</td></tr>
        <% } %>
        <% funnel.monthlyRows.forEach((item) => { %>
          <tr>
            <td><%= item.base %></td>
            <td><%= item.arrivedCount %></td>
            <td><%= item.passedCount %></td>
            <td><%= item.trainingCount %></td>
            <td><%= item.passRateText %></td>
            <td><%= item.trainingRateText %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<%- include('../../partials/footer') %>
