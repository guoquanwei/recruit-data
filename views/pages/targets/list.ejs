<%- include('../../partials/header') %>

<% if (notice) { %><div class="alert alert-success"><%= notice %></div><% } %>
<% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

<section class="filter-card">
  <form method="get">
    <div class="filter-grid">
      <%- include('../../partials/admin/search-select', { label: '月份', name: 'yearMonth', value: result.filters.yearMonth, items: result.options.months }) %>
      <%- include('../../partials/admin/search-select', { label: '基地', name: 'base', value: result.filters.base, items: result.options.bases }) %>
      <%- include('../../partials/admin/search-select', { label: '渠道', name: 'channel', value: result.filters.channel, items: result.options.channels }) %>
      <%- include('../../partials/admin/clearable-input', { label: '关键词', name: 'keyword', value: result.filters.keyword, placeholder: '基地/渠道/订单类型' }) %>
      <div class="filter-actions">
        <button class="btn btn-primary" type="submit">查询</button>
        <button class="btn btn-outline-secondary" type="button" data-reset-form>重置</button>
      </div>
    </div>
  </form>
</section>

<section class="table-card target-summary-card">
  <div class="table-actions">
    <h2 class="h5 mb-0">目标列表</h2>
    <span class="text-muted small"><%= result.summary.yearMonth || '全部月份' %></span>
  </div>
  <div class="target-summary-grid target-summary-grid-five">
    <% result.summary.cards.forEach((card) => { %>
      <div class="target-summary-metric target-summary-metric-<%= card.key %>">
        <span><%= card.label %></span>
        <strong><%= card.target %></strong>
        <% if (card.key !== 'total') { %>
          <small>渠道目标占比 <%= card.shareText %></small>
        <% } else { %>
          <small>当前筛选范围目标合计</small>
        <% } %>
      </div>
    <% }) %>
  </div>
  <div class="target-batch-title">基地开班批次汇总</div>
  <div class="target-batch-hint">目标列表仅展示有目标的基地和批次，基地汇总行为该基地所有渠道目标合计。</div>
  <div class="table-responsive target-batch-table-wrap">
    <table class="table align-middle target-batch-table">
      <thead>
        <tr>
          <th class="target-batch-base-col">基地</th>
          <th class="target-batch-channel-col">渠道</th>
          <th class="target-batch-target-col">渠道目标</th>
          <% result.summary.batchColumns.forEach((column) => { %>
            <th><%= column.label %></th>
          <% }) %>
        </tr>
      </thead>
      <tbody>
        <% if (result.summary.batchRows.length === 0) { %>
          <tr>
            <td class="text-center text-muted" colspan="<%= 3 + result.summary.batchColumns.length %>">暂无目标汇总数据。</td>
          </tr>
        <% } %>
        <% result.summary.batchRows.forEach((row) => { %>
          <tr class="<%= row.isBaseSummary ? 'target-batch-base-row' : '' %>">
            <% if (row.showBase) { %>
              <td rowspan="<%= row.baseRowSpan %>"><%= row.base %></td>
            <% } %>
            <td><%= row.channelLabel %></td>
            <td><%= row.monthlyTarget || '' %></td>
            <% row.batchTargets.forEach((target) => { %>
              <td><%= target || '' %></td>
            <% }) %>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% if (result.summary.page) { %>
    <%- include('../../partials/admin/pagination', { total: result.summary.totalBases, page: result.summary.page, filters: result.filters, basePath: '/targets', pageSizeOptions: [3] }) %>
  <% } %>
</section>

<%- include('../../partials/footer') %>
