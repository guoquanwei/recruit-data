<%- include('../../partials/header') %>

<% if (notice) { %><div class="alert alert-success"><%= notice %></div><% } %>
<% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>

<section class="filter-card">
  <form method="get">
    <div class="filter-grid">
      <%- include('../../partials/admin/search-select', { label: '月份', name: 'yearMonth', value: result.filters.yearMonth, items: result.options.months }) %>
      <%- include('../../partials/admin/search-select', { label: '基地', name: 'base', value: result.filters.base, items: result.options.bases }) %>
      <%- include('../../partials/admin/search-select', { label: '渠道', name: 'channel', value: result.filters.channel, items: result.options.channels }) %>
      <%- include('../../partials/admin/clearable-input', { label: '关键词', name: 'keyword', value: result.filters.keyword, placeholder: '基地/渠道/订单类型' }) %>
      <div class="filter-actions">
        <button class="btn btn-primary" type="submit">查询</button>
        <button class="btn btn-outline-secondary" type="button" data-reset-form>重置</button>
      </div>
    </div>
  </form>
</section>

<section class="table-card target-summary-card">
  <div class="table-actions">
    <h2 class="h5 mb-0">当月目标汇总</h2>
    <span class="text-muted small"><%= result.summary.yearMonth || '全部' %></span>
  </div>
  <div class="target-summary-grid">
    <div class="target-summary-metric">
      <span>需求总数</span>
      <strong><%= result.summary.totalTarget %></strong>
    </div>
    <div class="target-summary-metric">
      <span>基地数</span>
      <strong><%= result.summary.baseCount %></strong>
    </div>
    <div class="target-summary-metric">
      <span>有效渠道数</span>
      <strong><%= result.summary.channelCount %></strong>
    </div>
  </div>
  <div class="table-responsive">
    <table class="table table-hover align-middle target-summary-table">
      <thead>
        <tr><th>渠道</th><th>渠道目标</th><th>渠道目标占比</th></tr>
      </thead>
      <tbody>
        <% if (result.summary.channels.length === 0) { %>
          <tr><td class="text-center text-muted" colspan="3">暂无目标汇总数据。</td></tr>
        <% } %>
        <% result.summary.channels.forEach((channel) => { %>
          <tr>
            <td><%= channel.channel %></td>
            <td><%= channel.target %></td>
            <td><%= channel.shareText %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <div class="base-summary-list">
    <% if (result.summary.bases.length === 0) { %>
      <div class="base-summary-empty">暂无基地目标汇总。</div>
    <% } %>
    <% result.summary.bases.forEach((base) => { %>
      <div class="base-summary-card">
        <div class="base-summary-head">
          <span><%= base.base %></span>
          <strong><%= base.totalTarget %></strong>
        </div>
        <div class="base-summary-dates">
          <% const targetBreakdowns = result.summary.yearMonth ? base.dateTargets : base.monthTargets; %>
          <% if (targetBreakdowns.length === 0) { %>
            <span class="base-summary-muted"><%= result.summary.yearMonth ? '暂无日期拆解' : '暂无月份拆解' %></span>
          <% } %>
          <% targetBreakdowns.forEach((item) => { %>
            <span><%= item.label %> <strong><%= item.target %></strong></span>
          <% }) %>
        </div>
        <div class="base-summary-channels">
          <% base.channels.forEach((channel) => { %>
            <span><%= channel.label %> <%= channel.target %></span>
          <% }) %>
        </div>
      </div>
    <% }) %>
  </div>
</section>

<section class="import-card">
  <form class="row g-2 align-items-end" action="/targets/import" method="post" enctype="multipart/form-data">
    <div class="col-md-8">
      <label class="form-label">导入月度招聘目标 Excel</label>
      <input class="form-control" type="file" name="file" accept=".xlsx,.xls" required>
    </div>
    <div class="col-md-4">
      <button class="btn btn-primary" type="submit">按月覆盖导入</button>
    </div>
  </form>
</section>

<section class="table-card">
  <%
    const targetExportParams = new URLSearchParams();
    Object.entries(result.filters).forEach(([key, value]) => {
      if (value) targetExportParams.set(key, value);
    });
  %>
  <div class="table-actions">
    <h2 class="h5 mb-0">目标列表</h2>
    <div class="table-action-buttons">
      <a class="btn btn-sm btn-outline-secondary" href="<%= `/targets/export?${targetExportParams.toString()}` %>">导出</a>
      <a class="btn btn-sm btn-outline-primary" href="/targets/progress">查看达成进度</a>
    </div>
  </div>
  <div class="table-responsive">
    <table class="table table-hover align-middle">
      <thead>
        <tr>
          <th>月份</th><th>基地</th><th>渠道</th><th>订单类型</th><th>月度目标</th>
          <th>截止目标</th><th>实际入培</th><th>GAP</th><th>达成率</th>
        </tr>
      </thead>
      <tbody>
        <% if (result.rows.length === 0) { %>
          <tr><td class="text-center text-muted" colspan="9"><%= result.emptyMessage || '暂无目标数据，请先导入目标表。' %></td></tr>
        <% } %>
        <% result.rows.forEach((target) => { %>
          <tr>
            <td><%= target.yearMonth %></td>
            <td><%= target.base %></td>
            <td><%= target.channel %></td>
            <td><%= target.orderType %></td>
            <td><%= target.progress.monthlyTarget %></td>
            <td><%= target.progress.cutoffTarget %></td>
            <td><%= target.progress.actualTraining %></td>
            <td class="<%= target.progress.gap < 0 ? 'danger-text' : '' %>"><%= target.progress.gap %></td>
            <td class="<%= target.progress.achievementRate < 1 ? 'danger-text' : '' %>"><%= target.progress.achievementRateText %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <%- include('../../partials/admin/pagination', { total: result.total, page: result.page, filters: result.filters, basePath: '/targets' }) %>
</section>

<%- include('../../partials/footer') %>
