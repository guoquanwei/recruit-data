# 本地开发环境
# 本地和生产共用同一个 PostgreSQL 数据库；本地开发使用公网 host。
NODE_ENV=production
PORT=3000
TZ=Asia/Shanghai
DATABASE_URL=postgresql://<DB_USER>:<DB_PASSWORD>@pgm-8vb9x4vt2nmk1kcc1o.pgsql.zhangbei.rds.aliyuncs.com:5432/<DB_NAME>

